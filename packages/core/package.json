{
  "name": "@toon-protocol/core",
  "version": "1.2.0",
  "description": "Core library for Nostr-based ILP peer discovery and settlement",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./nip34": {
      "types": "./dist/nip34/index.d.ts",
      "import": "./dist/nip34/index.js"
    },
    "./toon": {
      "types": "./dist/toon/index.d.ts",
      "import": "./dist/toon/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "nostr",
    "interledger",
    "ilp",
    "settlement"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toon-protocol/town.git",
    "directory": "packages/core"
  },
  "author": "ALLiDoizCode",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ardrive/turbo-sdk": "^1.21.0",
    "@scure/bip32": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "@toon-format/toon": "^1.1.0",
    "arweave": "^1.15.5",
    "nostr-tools": "^2.20.0",
    "simple-git": "^3.32.3",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@toon-protocol/connector": ">=2.2.0"
  },
  "peerDependenciesMeta": {
    "@toon-protocol/connector": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "yaml": "^2.8.2"
  }
}
