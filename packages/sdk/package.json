{
  "name": "@toon-protocol/sdk",
  "version": "0.4.0",
  "description": "TOON SDK for building ILP-gated Nostr services",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:docker": "vitest run --config vitest.e2e.config.ts -- tests/e2e/docker-publish-event-e2e.test.ts",
    "test:e2e:docker:solana": "vitest run --config vitest.e2e.config.ts -- tests/e2e/docker-solana-settlement-e2e.test.ts",
    "test:e2e:docker:mina": "vitest run --config vitest.e2e.config.ts -- tests/e2e/docker-mina-settlement-e2e.test.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "toon",
    "nostr",
    "ilp",
    "interledger",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toon-protocol/town.git",
    "directory": "packages/sdk"
  },
  "author": "ALLiDoizCode",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/curves": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "@scure/bip32": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "@ardrive/turbo-sdk": "^1.19.0",
    "@toon-protocol/core": "workspace:*",
    "nostr-tools": "^2.20.0"
  },
  "peerDependencies": {
    "@toon-protocol/connector": ">=2.2.0"
  },
  "peerDependenciesMeta": {
    "@toon-protocol/connector": {
      "optional": true
    }
  },
  "devDependencies": {
    "@toon-protocol/connector": "^2.2.0",
    "@toon-protocol/relay": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "viem": "^2.0.0",
    "vitest": "^1.0.0",
    "ws": "^8.0.0"
  }
}
