{
  "name": "@toon-protocol/town",
  "version": "0.4.0",
  "description": "TOON Town - SDK-based relay with startTown() API and CLI for ILP-gated Nostr services",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "toon-town": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "keywords": [
    "toon",
    "nostr",
    "ilp",
    "interledger",
    "relay",
    "town"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toon-protocol/town.git",
    "directory": "packages/town"
  },
  "author": "ALLiDoizCode",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@toon-protocol/connector": "^2.2.0",
    "@toon-protocol/core": "workspace:*",
    "@toon-protocol/relay": "workspace:*",
    "@toon-protocol/sdk": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.11.10",
    "nostr-tools": "^2.20.0",
    "viem": "^2.47.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "ws": "^8.0.0"
  }
}
